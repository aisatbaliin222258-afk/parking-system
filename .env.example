# Example environment variables for production and development

# ===== SERVER =====
PORT=3000
NODE_ENV=production

# ===== FRONTEND CORS =====
# Production: Firebase hosted frontend
FRONTEND_ORIGIN=https://parkingsystem-dc7c0.web.app
# Development: Also allowed in dev mode (see server.js allowedOrigins)

# ===== DATABASE =====
# For development (local):
# MONGO_URI=mongodb://127.0.0.1:27017/myDatabase
#
# For production (MongoDB Atlas):
MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/parking_db?retryWrites=true&w=majority

# ===== SECURITY =====
# JWT Secret - Use a strong, random string (min 32 chars recommended)
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production

# Comma-separated API keys for sensor/service authentication
API_KEYS=dev-key,production-key-1

# ===== OPTIONAL =====
# Node.js memory limit (useful for low-memory environments)
NODE_OPTIONS=--max-old-space-size=512

# Application environment
APP_NAME=CCTV Detection System
APP_VERSION=1.0.0
